{
  "name": "@openpowershift/oscd-editor-cleanup",
  "version": "0.0.0",
  "description": "OpenSCD editor plugin for cleaning unreferenced SCL DataSets, Control Blocks and DataType templates.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OpenPowerShift/oscd-editor-cleanup.git"
  },
  "bugs": {
    "url": "https://github.com/OpenPowerShift/oscd-editor-cleanup/issues"
  },
  "homepage": "https://openscd.org",
  "keywords": [
    "OpenSCD",
    "iec61850",
    "OpenPowerShift",
    "Sysconex"
  ],
  "contributors": [],
  "author": "Daniel Mulholland",
  "license": "Apache-2.0",
  "exports": {
    ".": "./dist/oscd-editor-cleanup.js",
    "./oscd-editor-cleanup.js": "./dist/oscd-editor-cleanup.js"
  },
  "files": [
    "/dist/",
    "!/dist/*.spec.*",
    "!/dist/*.test.*"
  ],
  "scripts": {
    "lint": "eslint .",
    "format": "eslint . --fix",
    "analyze": "cem analyze --litelement --exclude demo/* --exclude dist/* --exclude src/**/*.spec.ts --exclude src/**/*.test.ts --exclude coverage/*",
    "copy-demo": "cp -r ./demo ./dist/",
    "start": "npm run build:docs && npm run build && cp -r ./dist/docs ./demo/ && concurrently -k -r \"tsc --watch --preserveWatchOutput\" \"chokidar './demo/**/*' -c 'npm run copy-demo'\" \"wds --node-resolve --hmr\"",
    "start:bundle": "npm run bundle && concurrently -k -r \"rollup -c rollup.config.js --watch\" \"wds --watch\"",
    "build": "rimraf dist && mkdir dist && npm run copy-demo && npm run analyze -- --exclude dist && tsc ",
    "bundle": "rimraf dist && rollup -c rollup.config.js",
    "build:docs": "antora antora-playbook.yml",
    "deploy": "npm run build:docs && npm run bundle && cp -r dist/docs dist/demo/ && gh-pages --dist 'dist'",
    "test": "npm run build && wtr --coverage",
    "test:watch": "npm run build && concurrently -k -r \"tsc --watch --preserveWatchOutput\" \"wtr --watch\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@lit/localize": "^0.12.2",
    "@omicronenergy/oscd-scl-dialogs": "^0.0.12",
    "@omicronenergy/oscd-shell": "^0.0.13",
    "@webcomponents/scoped-custom-element-registry": "^0.0.10",
    "@omicronenergy/oscd-ui": "^0.0.11",
    "@open-wc/scoped-elements": "^3.0.6",
    "@openscd/oscd-api": "^0.1.6",
    "@openscd/scl-lib": "^2.0.0",
    "lit": "^3.3.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@antora/cli": "^3.1.9",
    "@antora/site-generator": "^3.1.9",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@custom-elements-manifest/analyzer": "^0.10.5",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.34.0",
    "@open-wc/dev-server-hmr": "^0.2.0",
    "@open-wc/eslint-config": "^13.0.0",
    "@open-wc/testing": "4.0.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.4",
    "@types/mocha": "^10.0.10",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "@web/dev-server": "^0.4.6",
    "@web/dev-server-polyfill": "^1.0.6",
    "@web/rollup-plugin-import-meta-assets": "^2.3.0",
    "@web/test-runner": "0.20.2",
    "@web/test-runner-commands": "0.9.0",
    "@web/test-runner-playwright": "0.11.1",
    "chokidar-cli": "^3.0.0",
    "playwright": "1.54.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-html": "^8.1.3",
    "eslint-plugin-lit": "^2.1.1",
    "eslint-plugin-lit-a11y": "^5.1.1",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-tsdoc": "^0.4.0",
    "eslint-plugin-wc": "^3.0.1",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.5",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "rollup": "^4.48.1",
    "rollup-plugin-copy": "^3.5.0",
    "sinon": "^21.0.0",
    "typedoc": "^0.28.11",
    "typescript": "^5.9.2"
  },
  "overrides": {
    "playwright": "1.54.1"
  },
  "customElements": "custom-elements.json",
  "prettier": {
    "singleQuote": true,
    "arrowParens": "avoid"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write",
      "eslint"
    ]
  }
}
